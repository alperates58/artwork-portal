APP_NAME="Artwork Portal"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Europe/Istanbul
APP_LOCALE=tr

# Kurulum sihirbazı tarafından otomatik set edilir
APP_INSTALLED=false

LOG_CHANNEL=daily
LOG_LEVEL=error

# ─── Veritabanı ───────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=artwork_portal
DB_USERNAME=portal_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ─── Cache & Queue ────────────────────────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=redissecret
REDIS_PORT=6379

# ─── DigitalOcean Spaces ─────────────────────────────────────
FILESYSTEM_DISK=spaces
DO_SPACES_KEY=your-spaces-key
DO_SPACES_SECRET=your-spaces-secret
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=artwork-portal-prod
DO_SPACES_URL=https://artwork-portal-prod.fra1.digitaloceanspaces.com

# Presigned URL geçerlilik süresi (dakika)
ARTWORK_DOWNLOAD_TTL=15

# ─── Mikro ERP Entegrasyonu (Faz 2) ──────────────────────────
MIKRO_ERP_URL=
MIKRO_ERP_KEY=
MIKRO_USE_DIRECT_DB=false
MIKRO_SYNC_INTERVAL=60

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="portal@sirketiniz.com"
MAIL_FROM_NAME="${APP_NAME}"
